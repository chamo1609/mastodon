- content_for :page_title do
  = t('admin.settings.chamomile.title')

- content_for :heading do
  %h1= t('admin.settings.title')
  = render partial: 'admin/settings/shared/links'

= simple_form_for @admin_settings, url: admin_settings_chamomile_path, html: { method: :patch, multipart: true } do |f|
  = render 'shared/error_messages', object: @admin_settings

  %p.lead= t('admin.settings.chamomile.preamble')

  %h2 서버 기본 설정

  .fields-group
    = f.input :status_length_limit,
              as: :integer,
              input_html: { min: 1 },
              label: '발행 툿 최대 글자수 설정',
              wrapper: :with_block_label

  %h2 편의 기능

  .fields-group
    = f.input :chamomile_dice_enabled,
              as: :boolean,
              label: '주사위 기능 활성화 ([[1d100]] 명령어 사용)',
              wrapper: :with_label

  .fields-group
    = f.input :chamomile_markdown_enabled,
              as: :boolean,
              label: '마크다운 문법 활성화',
              wrapper: :with_label

  %h2 관리 및 보안

  .fields-group
    = f.input :chamomile_dm_admin_only,
              as: :boolean,
              label: '관리자 미포함 DM 차단 (관리자가 1명 이상 태그되어야 DM 발송 가능)',
              wrapper: :with_label

  %h2 커스텀 게시판 설정

  .fields-group
    %p.hint 게시판 이름과 연결될 해시태그(링크)를 짝지어 입력하세요.

    - boards = @admin_settings.chamomile_boards || []
    
    %table{ style: 'margin-top: 15px;' }
      %tbody
        - 10.times do |i|
          - board = boards[i] || {}
          %tr
            %td
              = text_field_tag 'form_admin_settings[chamomile_boards][][name]', board['name'] || board[:name], placeholder: '이름', style: 'width: 140px !important; display: block !important;'
            %td{ width: '20' }
            %td
              = text_field_tag 'form_admin_settings[chamomile_boards][][tag]', board['tag'] || board[:tag], placeholder: '해시태그', style: 'width: 140px !important; display: block !important;'
          %tr
            %td{ height: '10', colspan: '3' }

  %h2 커스텀 테마 설정

  .fields-group
    %p.hint 사이트 테마로 '커스텀 테마'를 선택한 사용자에게 적용될 브랜드 색상과 이미지를 설정합니다.

    %h3{ style: 'margin-top: 20px; margin-bottom: 10px; color: var(--color-text-secondary);' } 라이트 모드 설정
    .input
      = label_tag :chamomile_brand_light, '브랜드 컬러 (버튼, 링크 등 강조색)'
      = color_field_tag :chamomile_brand_light, Setting.chamomile_brand_light || '#94ca16'
    .input
      = label_tag :chamomile_text_on_brand_light, '브랜드 컬러 위 텍스트 색상'
      = color_field_tag :chamomile_text_on_brand_light, Setting.chamomile_text_on_brand_light || '#ffffff'
    .input
      = label_tag :chamomile_bg_light, '배경 컬러 (기본 배경색)'
      = color_field_tag :chamomile_bg_light, Setting.chamomile_bg_light || '#fffef7'
    .input
      = label_tag :chamomile_panel_light, '패널 배경 컬러 (글이 표시되는 영역)'
      = color_field_tag :chamomile_panel_light, Setting.chamomile_panel_light || '#ffffff'
    .input
      = label_tag :chamomile_text_light, '텍스트 컬러 (기본 글자색)'
      = color_field_tag :chamomile_text_light, Setting.chamomile_text_light || '#303030'

    %h3{ style: 'margin-top: 30px; margin-bottom: 10px; color: var(--color-text-secondary);' } 다크 모드 설정
    .input
      = label_tag :chamomile_brand_dark, '브랜드 컬러 (버튼, 링크 등 강조색)'
      = color_field_tag :chamomile_brand_dark, Setting.chamomile_brand_dark || '#ffdb63'
    .input
      = label_tag :chamomile_text_on_brand_dark, '브랜드 컬러 위 텍스트 색상'
      = color_field_tag :chamomile_text_on_brand_dark, Setting.chamomile_text_on_brand_dark || '#6a3f00'
    .input
      = label_tag :chamomile_bg_dark, '배경 컬러 (기본 배경색)'
      = color_field_tag :chamomile_bg_dark, Setting.chamomile_bg_dark || '#1e2028'
    .input
      = label_tag :chamomile_panel_dark, '패널 배경 컬러 (글이 표시되는 영역)'
      = color_field_tag :chamomile_panel_dark, Setting.chamomile_panel_dark || '#43433e'
    .input
      = label_tag :chamomile_text_dark, '텍스트 컬러 (기본 글자색)'
      = color_field_tag :chamomile_text_dark, Setting.chamomile_text_dark || '#ffffff'

  .fields-group
    %h2 커스텀 테마 이미지 설정
    
    .input.horizontal-options{ style: 'margin-top: 15px;' }
      = label_tag :custom_logo_light, '라이트 모드 로고 이미지'
      = file_field_tag :custom_logo_light, accept: 'image/*'
      - current_logo_light = SiteUpload.find_by(var: 'custom_logo_light')
      - if current_logo_light&.file?
        %div{ style: 'width: 100%; margin-top: 10px;' }
          = image_tag current_logo_light.file.url, width: '200', style: 'width: 200px; max-height: 50px; object-fit: contain; display: block; border-radius: 4px; background: rgba(0,0,0,0.1); padding: 5px; margin-bottom: 5px;'
          = link_to admin_site_upload_path(current_logo_light), data: { method: :delete }, class: 'link-button link-button--destructive' do
            = material_symbol 'delete'
            = t('admin.site_uploads.delete')

    .input.horizontal-options
      = label_tag :custom_background_light, '라이트 모드 배경 이미지'
      = file_field_tag :custom_background_light, accept: 'image/*'
      - current_bg_light = SiteUpload.find_by(var: 'custom_background_light')
      - if current_bg_light&.file?
        %div{ style: 'width: 100%; margin-top: 10px;' }
          = image_tag current_bg_light.file.url, width: '300', style: 'width: 300px; max-height: 100px; object-fit: cover; display: block; border-radius: 4px; margin-bottom: 5px;'
          = link_to admin_site_upload_path(current_bg_light), data: { method: :delete }, class: 'link-button link-button--destructive' do
            = material_symbol 'delete'
            = t('admin.site_uploads.delete')

    .input.horizontal-options{ style: 'margin-top: 15px;' }
      = label_tag :custom_logo_dark, '다크 모드 로고 이미지'
      = file_field_tag :custom_logo_dark, accept: 'image/*'
      - current_logo_dark = SiteUpload.find_by(var: 'custom_logo_dark')
      - if current_logo_dark&.file?
        %div{ style: 'width: 100%; margin-top: 10px;' }
          = image_tag current_logo_dark.file.url, width: '200', style: 'width: 200px; max-height: 50px; object-fit: contain; display: block; border-radius: 4px; background: rgba(0,0,0,0.1); padding: 5px; margin-bottom: 5px;'
          = link_to admin_site_upload_path(current_logo_dark), data: { method: :delete }, class: 'link-button link-button--destructive' do
            = material_symbol 'delete'
            = t('admin.site_uploads.delete')

    .input.horizontal-options
      = label_tag :custom_background_dark, '다크 모드 배경 이미지'
      = file_field_tag :custom_background_dark, accept: 'image/*'
      - current_bg_dark = SiteUpload.find_by(var: 'custom_background_dark')
      - if current_bg_dark&.file?
        %div{ style: 'width: 100%; margin-top: 10px;' }
          = image_tag current_bg_dark.file.url, width: '300', style: 'width: 300px; max-height: 100px; object-fit: cover; display: block; border-radius: 4px; margin-bottom: 5px;'
          = link_to admin_site_upload_path(current_bg_dark), data: { method: :delete }, class: 'link-button link-button--destructive' do
            = material_symbol 'delete'
            = t('admin.site_uploads.delete') 

  .actions
    = f.button :button, t('generic.save_changes'), type: :submit